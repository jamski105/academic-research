  {
    "id": "oa-03",
    "description": "DOAB-Fetcher: OA-Buch via DOAB-Eintrag — erwartet success oder begruendetes metadata_only",
    "agent": "doabooks-fetcher",
    "input": {
      "isbn": "978-3-030-68953-1",
